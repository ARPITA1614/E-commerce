<div class="product-grid">
  <% @products.each do |product| %>
    <div class="product-card">
      <div class="product-image">
        <% if product.image.present? %>
          <%= image_tag product.image, alt: product.name %>
        <% else %>
          <div class="placeholder">No Image</div>
        <% end %>
      </div>      
      <div class="product-info">
        <h3 class="product-name"><%= link_to product.name, product %></h3>
        <p class="product-price">Rs. <%= product.price %></p>
        <div class="actions">
        <% if user_signed_in? %>
          <% if current_user.wishlist_products.include?(product) %>
            <%= button_to 'Remove from Wishlist', wishlist_path(product), method: :delete %>
        <% else %>
          <%= button_to 'Add to Wishlist', wishlists_path(product_id: product.id), method: :post %>
        <% end %>
  <% end %>
        <%= link_to 'Show', product, class: 'btn btn-outline' %>      
        <%= button_to "Add to Cart", items_path(product_id: product.id), method: :post, class: "btn btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
