<div class="product-grid">
  <% @products.each do |product| %>
    <div class="product-card">
      <div class="product-image">
        <% if product.image.present? %>
          <%= image_tag product.image, alt: product.name %>
        <% else %>
          <div class="placeholder">No Image</div>
        <% end %>
      </div>  
      <% if user_signed_in? %>
          <% if current_user.wishlist_products.include?(product) %>
            <%= button_to wishlist_path(product), method: :delete,remote: true do %>
              <%= image_tag "heart.jpeg", alt: "heart", size: "25x25", method: :post %>
            <% end %>
          <% else %>
            <%=button_to wishlists_path(product_id: product.id), method: :post,remote: true do %>
              <%= image_tag "heart2.png", alt: "heart", size: "25x25", method: :post %>
            <% end %>
          <% end %>
        <% end %>    
      <div class="product-info">
        <h3 class="product-name"><%= link_to product.name, product %></h3>
        <p class="product-price">Rs. <%= product.price %></p>
        <div class="actions">     
        <%= link_to 'Show', product, class: 'btn btn-outline' %>      
        <%= button_to "Add to Cart", items_path(product_id: product.id), method: :post, class: "btn btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
