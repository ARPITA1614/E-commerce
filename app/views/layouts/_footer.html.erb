<div class="container">
  <footer class="py-5">
    <div class="row justify-content-between">
      
      <% ['Shop', 'Support'].each do |section| %>
        <div class="col-6 col-md-2 mb-3">
          <h5 class="fw-bold text-uppercase"><%= section %></h5>
          <ul class="nav flex-column">
            <li class="nav-item mb-2"><%= link_to "Home", root_path, class: "nav-link p-0 text-body-secondary" %></li>
            <li class="nav-item mb-2"><%= link_to "Products", products_path, class: "nav-link p-0 text-body-secondary" %></li>
            <li class="nav-item mb-2"><%= link_to "FAQs", "#", class: "nav-link p-0 text-body-secondary" %></li>
            <li class="nav-item mb-2"><%= link_to "About Us", "#", class: "nav-link p-0 text-body-secondary" %></li>
          </ul>
        </div>
      <% end %>

      <div class="col-md-5 offset-md-2 mb-3">
        <%= form_with url: "#", method: :post do |f| %>
          <h5 class="fw-bold">Subscribe to our newsletter</h5>
          <p class="text-body-secondary">Get the latest updates on new arrivals and sales.</p>
          <div class="d-flex flex-column flex-sm-row w-100 gap-2">
            <%= f.label :email, class: "visually-hidden" %>
            <%= f.email_field :email, class: "form-control", placeholder: "Email address", required: true %>
            <%= f.submit "Subscribe", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="d-flex flex-column flex-sm-row justify-content-between py-4 my-4 border-top">
      <p>&copy; <%= Time.current.year %> EcommerceApp, Inc. All rights reserved.</p>
      <ul class="list-unstyled d-flex">
        <li class="ms-3"><%= link_to "Instagram", "#", class: "link-body-emphasis" %></li>
        <li class="ms-3"><%= link_to "Facebook", "#", class: "link-body-emphasis" %></li>
      </ul>
    </div>
  </footer>
</div>
