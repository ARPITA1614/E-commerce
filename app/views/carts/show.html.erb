<h1>Your Shopping Cart</h1>
<% if @items.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>Product</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Subtotal</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @items.each do |item| %>
        <tr>
          <td><%= item.product.name %></td>
          <td>Rs. <%= item.price %></td>
          <td>
            <div class="d-flex align-items-center">
              <%= button_to '-', item_path(item, operation: 'subtract'), method: :patch, class: "btn btn-sm btn-outline-secondary" %>
              <span class="mx-2"><%= item.quantity %></span>
              <%= button_to '+', item_path(item, operation: 'add'), method: :patch, class: "btn btn-sm btn-outline-secondary" %>
            </div>
          </td>
          <td>Rs. <%= item.price * item.quantity %></td>
          <td>
            <%= button_to 'Remove', item_path(item), method: :delete, class: "btn btn-sm btn-danger", data: { confirm: 'Are you sure?' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <h3>Total: Rs. <%= @cart.items.sum { |i| i.price * i.quantity } %></h3>
<% else %>
  <p>Your cart is empty. <%= link_to 'Start shopping', products_path %></p>
<% end %>
